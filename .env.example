# VoiceGameControl Configuration Example
# 复制此文件为 .env 并填入你的配置

# === ASR - Aliyun DashScope (Required) ===
ASR_API_KEY=your_aliyun_api_key_here
ASR_MODEL=qwen3-asr-flash-realtime-2026-02-10
ASR_MAX_SILENCE_MS=400

# === Hotkey ===
HOTKEY=<f9>

# === Server ===
HOST=127.0.0.1
PORT=18234

# === Auto-start ===
AUTO_START_ASR=false
